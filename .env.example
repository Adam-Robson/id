# Cloudflare R2 (S3-compatible) — used by src/lib/r2.ts
# Find these in the Cloudflare dashboard under R2 > Manage R2 API Tokens,
# or recover the live values with: vercel login && vercel link && vercel env pull .env.local

# R2 S3 API endpoint, e.g. https://<account_id>.r2.cloudflarestorage.com
S3_API=

# R2 API token credentials
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=

# Name of the R2 bucket holding audio files and contact submissions
BUCKET_NAME=

# Cloudflare account
ACCOUNT_ID=
API_TOKEN=
